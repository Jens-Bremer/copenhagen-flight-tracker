<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="format-detection" content="telephone=no, date=no, address=no, email=no">
  <meta name="color-scheme" content="light">
  <meta name="theme-color" content="#f9f2e3">
  <title>Copenhagen Flight Tracker</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous">
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>${INLINE_STYLES}</style>
</head>
<body>
  <header class="site-header">
    <div class="site-header__inner">
      <h1 class="site-header__title">Copenhagen <em>Flight</em> Tracker</h1>
      <nav class="site-header__meta">
        <span id="header-range">Data through —</span>
        <span id="header-generated">Generated —</span>
      </nav>
    </div>
    <div class="stripe-ribbon" aria-hidden="true">
      <div class="stripe-ribbon__red"></div>
      <div class="stripe-ribbon__orange"></div>
      <div class="stripe-ribbon__yellow"></div>
    </div>
  </header>

  <main class="page-main">
    <!-- 1. Filters bar -->
    <section class="filters" aria-label="Filters">
      <div class="filters__row">
        <div class="filters__group" id="route-toggle"></div>
        <div class="filters__group" id="airline-filter"></div>
      </div>
    </section>

    <!-- 2. Hero summary -->
    <section class="panel hero-summary" aria-label="Quick summary">
      <div id="hero-best-time" class="hero-card"></div>
      <div id="hero-market" class="hero-card"></div>
      <div id="hero-book-when" class="hero-card"></div>
    </section>

    <!-- 3. Calendar -->
    <section class="panel" aria-label="Calendar">
      <h2 class="panel__heading">Calendar — cheapest observed price per day</h2>
      <div class="calendar-nav">
        <button id="cal-prev" class="filter-chip" aria-label="Previous month">← Prev</button>
        <span id="cal-month-label" class="calendar-nav__label"></span>
        <button id="cal-next" class="filter-chip" aria-label="Next month">Next →</button>
      </div>
      <div id="calendar"></div>
    </section>

    <!-- 3. Drill-down (active when a date is selected) -->
    <section class="panel" id="drilldown-panel" aria-label="Flights for selected date">
      <h2 class="panel__heading"><span id="drilldown-title">Pick a day in the calendar</span></h2>
      <div id="drilldown-sort" class="drilldown-sort"></div>
      <div class="drilldown-grid">
        <div id="drilldown"></div>
        <aside id="drilldown-rail">
          <div id="verdict-card" class="verdict-card is-hidden"></div>
          <div id="price-history-wrap" class="chart-wrap is-hidden">
            <canvas id="price-history-chart" aria-label="Price over time" role="img"></canvas>
          </div>
        </aside>
      </div>
    </section>

    <!-- 4. Price trends -->
    <section class="panel" aria-label="Price trends">
      <h2 class="panel__heading">Price trends</h2>
      <p class="panel__subtitle">How prices have changed over time, and when they are typically cheapest</p>
      <div class="chart-wrap"><canvas id="leadtime-chart" role="img"></canvas></div>
      <div id="airline-leadtime-legend" class="airline-pill-legend" aria-label="Airline filter for booking-window chart"></div>
      <div class="chart-wrap"><canvas id="airline-leadtime-chart" role="img" aria-label="Per-airline price by days before departure"></canvas></div>
      <p id="sweet-spot-headline" class="headline"></p>
    </section>

    <!-- 5. Airline histograms -->
    <section class="panel" aria-label="Airline price distributions">
      <h2 class="panel__heading">Price distribution by airline</h2>
      <p class="panel__subtitle">Where prices typically fall — each bar is one 5 euro bin</p>
      <div id="histograms-container" class="trends-grid"></div>
    </section>

    <!-- 6. Weekend pairs -->
    <section class="panel" aria-label="Cheapest weekend pairs">
      <h2 class="panel__heading">Weekend trips</h2>
      <p class="panel__subtitle">Cheapest Friday to Sunday round-trip combinations</p>
      <div id="weekend-pairs"></div>
    </section>

    <!-- 7. Cheapness footer (dow + month) -->
    <section class="panel" aria-label="Cheapest day of week and month">
      <h2 class="panel__heading">Cheapest days and months to fly</h2>
      <p class="panel__subtitle">Price spread per day of week and month — box shows min, Q1, median, Q3, max</p>
      <div class="trends-grid">
        <div class="chart-wrap"><canvas id="dow-chart" role="img"></canvas></div>
        <div class="chart-wrap"><canvas id="month-chart" role="img"></canvas></div>
      </div>
    </section>

    <!-- 7b. Per-airline price boxplots -->
    <section class="panel" aria-label="Price spread by airline">
      <h2 class="panel__heading">Price spread by airline</h2>
      <p class="panel__subtitle">Distribution of observed prices per airline, one chart per route</p>
      <div id="airline-boxplots-container" class="trends-grid"></div>
    </section>

    <!-- 8. Time-of-day price heatmap -->
    <section class="panel" aria-labelledby="timeheat-heading">
      <h2 class="panel__heading" id="timeheat-heading">Prices by departure time</h2>
      <p class="panel__subtitle">Cheapest hours to fly, by day of week</p>
      <div id="timeheat-container" class="timeheat-wrap"></div>
    </section>

    <!-- 9. How prices change as departure approaches -->
    <section class="panel" aria-labelledby="normprog-heading">
      <h2 class="panel__heading" id="normprog-heading">How prices change as departure approaches</h2>
      <p class="panel__subtitle">0% equals first time we saw this flight. Shows whether prices tend to rise or fall over time</p>
      <div class="chart-wrap">
        <canvas id="normprog-chart" aria-label="Normalised price change by days before departure" role="img"></canvas>
      </div>
    </section>
  </main>

  <footer class="page-footer">
    Copenhagen Flight Tracker · generated <span id="footer-generated">—</span>
  </footer>

  <script type="application/json" id="DATA_METADATA">${DATA_METADATA}</script>
  <script type="application/json" id="DATA_CALENDAR">${DATA_CALENDAR}</script>
  <script type="application/json" id="DATA_FLIGHTS">${DATA_FLIGHTS}</script>
  <script type="application/json" id="DATA_ANALYSIS">${DATA_ANALYSIS}</script>
  <script type="application/json" id="DATA_SUMMARY">${DATA_SUMMARY}</script>
  <div id="data-load-error" style="display:none;position:fixed;inset:0;z-index:9999;background:#fff3cd;color:#856404;padding:2rem;font-family:sans-serif;font-size:1.1rem;"></div>

  <script>${INLINE_CHART_JS}</script>
  <script>${INLINE_DATE_ADAPTER_JS}</script>
  <script>${INLINE_BOXPLOT_JS}</script>
  <script>${INLINE_APP_JS}</script>
</body>
</html>
