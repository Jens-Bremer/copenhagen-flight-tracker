<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="format-detection" content="telephone=no, date=no, address=no, email=no">
  <meta name="color-scheme" content="light">
  <meta name="theme-color" content="#f9f2e3">
  <title>Airline Trends — Copenhagen Flight Tracker</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous">
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>${INLINE_STYLES}</style>
</head>
<body>
  ${INLINE_HEADER}

  <main class="page-main">
    <section class="panel" aria-label="When should I buy?">
      <h2 class="panel__heading">When should I buy?</h2>
      <p class="panel__subtitle">Recent direction of daily-min prices and the historically cheapest booking window</p>
      <div id="momentum-container"></div>
    </section>

    <section class="panel" aria-label="Airline price trends">
      <h2 class="panel__heading">Airline Price Trends by Booking Window</h2>
      <p class="panel__subtitle">Median price progression & interquartile range per airline, with dashed ±σ volatility band overlay</p>
      <div class="chart-wrap"><canvas id="airline-trend-out" role="img" aria-label="CPH to AMS price trends by airline"></canvas></div>
      <div class="chart-wrap"><canvas id="airline-trend-back" role="img" aria-label="AMS to CPH price trends by airline"></canvas></div>
    </section>

    <section class="panel matrix-section" aria-label="Weekly seasonality matrix">
      <h2 class="panel__heading">Weekly Seasonality Matrix</h2>
      <p class="panel__subtitle">Does the day of the week you buy matter? This matrix shows whether buying on a given weekday is historically cheaper or pricier for Friday, Saturday, or Sunday flights — compared to that airline's average price on the route.</p>

      <div class="matrix-explainer">
        <p class="matrix-explainer__how-to-read">
          <strong>How to read:</strong> Select an airline, then find the row for the day you plan to buy and the column for your departure day.
          The cell colour shows how much prices on that combination differ from average. <strong>High</strong> means a strong difference (&gt;15%) —
          hover the cell to see whether it's cheaper or more expensive. <strong>No</strong> means no meaningful pattern.
          A <strong>High</strong> cell in a cheap direction = good day to buy. A <strong>High</strong> cell in an expensive direction = avoid that day.
        </p>
        <div class="matrix-explainer__legend">
          <span class="matrix-legend-item"><span class="matrix-legend-swatch" style="background:#c23c2a;"></span><strong>High</strong> &gt;15% difference</span>
          <span class="matrix-legend-item"><span class="matrix-legend-swatch" style="background:#fdaa4f;"></span><strong>Med</strong> 5–15%</span>
          <span class="matrix-legend-item"><span class="matrix-legend-swatch" style="background:#fde4a3;"></span><strong>Low</strong> 1–5%</span>
          <span class="matrix-legend-item"><span class="matrix-legend-swatch" style="background:#e8e8e8;"></span><strong>No</strong> ≤1%, no pattern</span>
          <span class="matrix-legend-item"><span class="matrix-legend-swatch matrix-legend-swatch--empty">·</span>not enough data</span>
        </div>
      </div>

      <div id="airline-matrix-container"></div>
    </section>

    <section class="panel" aria-label="Recent price drops">
      <h2 class="panel__heading">Recent Price Drops</h2>
      <p class="panel__subtitle">Flights that have persisted at a notably low price across multiple scrapes</p>
      <div id="price-drops-container"></div>
    </section>
  </main>

  ${INLINE_FOOTER}

  <script type="application/json" id="DATA_AIRLINE_TRENDS">${DATA_AIRLINE_TRENDS}</script>
  <script type="application/json" id="DATA_AIRLINE_MATRIX">${DATA_AIRLINE_MATRIX}</script>
  <script type="application/json" id="DATA_PRICE_PERCENTILE">${DATA_PRICE_PERCENTILE}</script>
  <script type="application/json" id="DATA_MOMENTUM">${DATA_MOMENTUM}</script>
  <script type="application/json" id="DATA_VOLATILITY">${DATA_VOLATILITY}</script>
  <script type="application/json" id="DATA_PRICE_DROPS">${DATA_PRICE_DROPS}</script>
  <div id="data-load-error" style="display:none;position:fixed;inset:0;z-index:9999;background:#fff3cd;color:#856404;padding:2rem;font-family:sans-serif;font-size:1.1rem;"></div>

  <script>${INLINE_CHART_JS}</script>
  <script>${INLINE_APP_JS}</script>
  <script>${RENDER_AIRLINE_TRENDS}</script>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      try {
        renderAirlineTrends();
      } catch (e) {
        console.error('Failed to render airline trends:', e);
        document.getElementById('data-load-error').textContent = 'Failed to render airline trends. See console for details.';
        document.getElementById('data-load-error').style.display = 'block';
      }
      try {
        renderAirlineMatrix();
      } catch (e) {
        console.error('Failed to render airline matrix:', e);
      }
      try { renderPriceDrops(); } catch (e) { console.error('Failed to render price drops:', e); }
      try { renderPricePercentile(); } catch (e) { console.error('Failed to render price percentile:', e); }
      try { renderMomentum(); } catch (e) { console.error('Failed to render momentum:', e); }
    });
  </script>
</body>
</html>
