# Default: treat as text, normalize to LF in the repo, native on checkout.
* text=auto eol=lf

# PowerShell prefers CRLF on Windows.
*.ps1 text eol=crlf
*.psm1 text eol=crlf
*.cmd text eol=crlf
*.bat text eol=crlf

# Binary / opaque assets — never munge line endings.
*.db binary
*.sqlite binary
*.sqlite3 binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary

# Vendored frontend libraries — keep as shipped.
frontend/vendor/** binary
